{
  "name": "@besitos/offerwall-sdk",
  "version": "1.0.0-beta",
  "description": "Besitos Offerwall Mobile SDK for React Native and Expo",
  "main": "react-native/lib/index.js",
  "module": "react-native/lib/index.js",
  "types": "react-native/lib/index.d.ts",
  "source": "react-native/src/index.ts",
  "files": [
    "react-native.config.js",
    "react-native/src",
    "react-native/lib",
    "react-native/android",
    "react-native/ios",
    "react-native/BesitosOfferwallRN.podspec",
    "android",
    "ios",
    "!react-native/android/build",
    "!react-native/ios/build",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__"
  ],
  "scripts": {
    "build": "tsc --project react-native/tsconfig.build.json",
    "typescript": "tsc --noEmit --project react-native/tsconfig.json",
    "lint": "eslint \"**/*.{js,ts,tsx}\""
  },
  "keywords": [
    "react-native",
    "ios",
    "android",
    "besitos",
    "offerwall"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Jay-7stallions/besitos-offerwall-sdk.git"
  },
  "author": "Besitos <sdk@besitos.ai>",
  "license": "MIT",
  "peerDependencies": {
    "react-native": ">=0.73.0"
  },
  "react-native": {
    "platforms": {
      "android": {
        "sourceDir": "react-native/android"
      },
      "ios": {
        "project": "react-native/BesitosOfferwallRN.podspec"
      }
    }
  },
  "devDependencies": {
    "@types/react-native": "^0.73.0",
    "typescript": "^5.0.0"
  }
}
